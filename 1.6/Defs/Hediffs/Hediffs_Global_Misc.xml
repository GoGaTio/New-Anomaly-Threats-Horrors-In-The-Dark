<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <HediffDef>
    <defName>NAT_CollectorHypnosis</defName>
    <label>collector hypnosis</label>
    <description>An aftereffect of hypnosis by collector.</description>
    <hediffClass>HediffWithComps</hediffClass>
    <isBad>false</isBad>
    <comps>
      <li Class="HediffCompProperties_SeverityPerDay">
        <severityPerDay>-12.00</severityPerDay>
      </li>
    </comps>
    <stages>
      <li>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <setMax>0.1</setMax>
          </li>
        </capMods>
      </li>
    </stages>
    <givesInfectionPathways>
      <li>NAT_ByCollector</li>
    </givesInfectionPathways>
  </HediffDef>

  <InfectionPathwayDef>
    <defName>NAT_ByCollector</defName>
    <label>implanted by collector</label>
  </InfectionPathwayDef>

</Defs>