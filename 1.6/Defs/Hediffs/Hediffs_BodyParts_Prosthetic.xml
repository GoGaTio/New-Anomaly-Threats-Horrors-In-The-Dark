<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <HediffDef ParentName="AddedBodyPartBase">
    <defName>NAT_PhasepassGland</defName>
    <label>phasepass gland</label>
    <description>A modified human kidney reconfigured to heat the blood of a ghoul, allowing survival in extremely cold environments.</description>
    <spawnThingOnRemoved>NAT_PhasepassGland</spawnThingOnRemoved>
    <addedPartProps>
      <solid>true</solid>
      <partEfficiency>0.95</partEfficiency>
    </addedPartProps>
    <comps>
      <li Class="NAT.HediffCompProperties_GiveAbilityCharges">
        <abilityDefs>
          <li>NAT_PhaseTo</li>
        </abilityDefs>
      </li>
    </comps>
  </HediffDef>

  <ThingDef ParentName="BodyPartBionicBase">
    <defName>NAT_PhasepassGland</defName>
    <label>phasepass gland</label>
    <description>A special bioferrite prosthetic that actively heats a ghoul's blood, allowing it to survive in cold environments. The prosthetic replaces a ghoul's kidney, heating the blood as it passes through.\n\nDue to the extremely painful nature of the prosthetic, only ghouls can tolerate this enhancement.</description>
    <descriptionHyperlinks>
      <RecipeDef>NAT_InstallPhasepassGland</RecipeDef>
    </descriptionHyperlinks>
    <statBases>
      <Mass>0.3</Mass>
      <WorkToMake>24000</WorkToMake>
    </statBases>
    <techHediffsTags Inherit="False"/>
    <costList>
      <Bioferrite>50</Bioferrite>
      <Shard>1</Shard>
      <RevenantSpine>1</RevenantSpine>
    </costList>
    <tradeTags Inherit="false" />
    <recipeMaker Inherit="false">
      <workSpeedStat>GeneralLaborSpeed</workSpeedStat>
      <workSkill>Crafting</workSkill>
      <effectWorking>Smith</effectWorking>
      <soundWorking>Recipe_Smith</soundWorking>
      <unfinishedThingDef>UnfinishedHealthItemBionic</unfinishedThingDef>
      <skillRequirements>
        <Crafting>8</Crafting>
      </skillRequirements>
      <researchPrerequisite>NAT_PhasepassGland</researchPrerequisite>
      <recipeUsers>
        <li>BioferriteShaper</li>
      </recipeUsers>
      <displayPriority>160</displayPriority>
    </recipeMaker>
  </ThingDef>

  <RecipeDef ParentName="SurgeryInstallImplantBase">
    <defName>NAT_InstallPhasepassGland</defName>
    <label>install phasepass gland</label>
    <description>Install phasepass gland.</description>
    <descriptionHyperlinks>
      <ThingDef>BloodWarmer</ThingDef>
      <HediffDef>BloodWarmer</HediffDef>
    </descriptionHyperlinks>
    <jobString>Installing phasepass gland.</jobString>
    <anesthetize>true</anesthetize>
    <surgeryOutcomeEffect IsNull="True" />
    <ingredients>
      <li>
        <filter>
          <thingDefs>
            <li>NAT_PhasepassGland</li>
          </thingDefs>
        </filter>
        <count>1</count>
      </li>
    </ingredients>
    <fixedIngredientFilter>
      <thingDefs>
        <li>NAT_PhasepassGland</li>
      </thingDefs>
    </fixedIngredientFilter>
    <appliedOnFixedBodyParts>
      <li>Kidney</li>
    </appliedOnFixedBodyParts>
    <addsHediff>NAT_PhasepassGland</addsHediff>
  </RecipeDef>
  
</Defs>